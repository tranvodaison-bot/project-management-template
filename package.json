{
  "name": "ftz-erp",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "turbo run db:generate --filter=@ftz-erp/db",
    "db:migrate": "turbo run db:migrate --filter=@ftz-erp/db",
    "db:seed": "turbo run db:seed --filter=@ftz-erp/db",
    "setup": "bash infra/scripts/setup-dev.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.5.4",
    "typescript": "^5.7.3",
    "tsx": "^4.19.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
