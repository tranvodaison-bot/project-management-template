// Work & Plan Management: Tasks, Plans, PDCA, Kanban

// ── Plans (multi-level: Company → Department → Individual) ────────────────────
model Plan {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  parentId    String?  @db.Uuid
  title       String
  description String?
  planType    String   // 'strategic' | 'department' | 'individual' | 'project'
  level       String   // 'company' | 'department' | 'team' | 'personal'
  status      String   @default("DRAFT") // DRAFT | APPROVED | ACTIVE | COMPLETED | CANCELLED
  period      String?  // 'Q1-2025' | '2025' | '2025-W01'
  ownerId     String   @db.Uuid
  departmentId String? @db.Uuid
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Plan?  @relation("PlanHierarchy", fields: [parentId], references: [id])
  children Plan[] @relation("PlanHierarchy")
  tasks    Task[]

  @@index([tenantId, status])
  @@map("plans")
}

// ── Tasks ─────────────────────────────────────────────────────────────────────
model Task {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  planId      String?  @db.Uuid
  parentId    String?  @db.Uuid
  boardId     String?  @db.Uuid

  title       String
  description String?
  status      String   @default("TODO")  // TODO | IN_PROGRESS | IN_REVIEW | DONE | CANCELLED
  priority    String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  taskType    String   @default("task")  // 'task' | 'milestone' | 'subtask'

  assigneeId  String?  @db.Uuid
  reporterId  String   @db.Uuid
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?

  estimatedHours Float?
  actualHours    Float?

  // CDE link
  documentIds String[] @db.Uuid

  // Polymorphic module link (e.g., project, contract, wbs_node)
  moduleType  String?
  moduleRefId String?  @db.Uuid

  tags        String[]
  metadata    Json     @default("{}")
  position    Float    @default(0) // For kanban ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan     Plan?    @relation(fields: [planId], references: [id])
  parent   Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  children Task[]   @relation("TaskHierarchy")
  board    KanbanBoard? @relation(fields: [boardId], references: [id])
  comments TaskComment[]
  attachments TaskAttachment[]
  timelogs    TimeLog[]

  @@index([tenantId, status])
  @@index([assigneeId])
  @@index([moduleType, moduleRefId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @db.Uuid
  authorId  String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model TaskAttachment {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId     String @db.Uuid
  documentId String @db.Uuid
  addedById  String @db.Uuid
  addedAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

model TimeLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String   @db.Uuid
  userId      String   @db.Uuid
  hours       Float
  description String?
  logDate     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("time_logs")
}

// ── Kanban Boards ─────────────────────────────────────────────────────────────
model KanbanBoard {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String   @db.Uuid
  name     String
  ownerId  String   @db.Uuid
  scopeType String? // 'personal' | 'project' | 'team'
  scopeId   String? @db.Uuid
  columns  Json     @default("[]") // [{id, name, color, position}]
  settings Json     @default("{}")
  createdAt DateTime @default(now())

  tasks Task[]

  @@map("kanban_boards")
}
