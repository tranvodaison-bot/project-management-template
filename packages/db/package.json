{
  "name": "@ftz-erp/db",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./rls": "./src/rls.ts"
  },
  "prisma": {
    "schema": "prisma/schema"
  },
  "scripts": {
    "db:generate": "prisma generate --schema prisma/schema",
    "db:migrate": "prisma migrate dev --schema prisma/schema",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema",
    "db:push": "prisma db push --schema prisma/schema",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:studio": "prisma studio --schema prisma/schema",
    "db:reset": "prisma migrate reset --force --schema prisma/schema"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0"
  },
  "devDependencies": {
    "prisma": "^6.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
